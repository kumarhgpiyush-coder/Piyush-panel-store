{
  "version": 2,
  "builds": [
    {
      "src": "api/buy.js",
      "use": "@vercel/node"
    },
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/buy",
      "dest": "api/buy.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
